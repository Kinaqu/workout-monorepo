{
  "version": 2,
  "builds": [
    {
      "src": "public/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/register",
      "dest": "/register.html"
    },
    {
      "src": "/program",
      "dest": "/program.html"
    },
    {
      "src": "/history",
      "dest": "/history.html"
    },
    {
      "src": "/progress",
      "dest": "/progress.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}