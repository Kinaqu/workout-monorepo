{
  "name": "workout-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=dot",
    "check": "npm run typecheck && npm run test:ci && npm exec wrangler -- deploy --dry-run --strict",
    "d1:preflight-0004:local": "wrangler d1 execute DB --local --file scripts/sql/0004_schema_hardening_preflight.sql",
    "d1:postflight-0004:local": "wrangler d1 execute DB --local --file scripts/sql/0004_schema_hardening_postflight.sql"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.0",
    "@cloudflare/workers-types": "^4.20260312.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.9.48",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  }
}
